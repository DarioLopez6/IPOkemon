<Page
    x:Class="ProyectoVacioUWP_Base.CombatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProyectoVacioUWP_Base">

    <Grid Background="#121212">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="250" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ContentControl x:Name="ContenedorP1" 
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                            Height="550" Width="450"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

            <ContentControl x:Name="ContenedorP2" Grid.Column="1" 
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                            Height="550" Width="450"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <ContentControl.RenderTransform>
                    <ScaleTransform ScaleX="-1" CenterX="225"/>
                </ContentControl.RenderTransform>
            </ContentControl>
        </Grid>

        <Grid Grid.Row="1" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="10" Background="#25FF0000" CornerRadius="15" BorderBrush="#88FF0000" BorderThickness="2">
                <StackPanel Padding="10">
                    <TextBlock Text="JUGADOR 1 (WASD + QE)" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="txtW" Grid.Row="0" Grid.Column="0" Text="[W] FLOJO" Foreground="White" Margin="5"/>
                        <TextBlock x:Name="txtA" Grid.Row="0" Grid.Column="1" Text="[A] FUERTE" Foreground="Yellow" Margin="5"/>
                        <TextBlock x:Name="txtS" Grid.Row="1" Grid.Column="0" Text="[S] ESCUDO" Foreground="Cyan" Margin="5"/>
                        <TextBlock x:Name="txtD" Grid.Row="1" Grid.Column="1" Text="[D] RELAX" Foreground="LightGreen" Margin="5"/>
                        <TextBlock x:Name="txtQ" Grid.Row="2" Grid.Column="0" Text="[Q] POC. VIDA" Foreground="Salmon" Margin="5"/>
                        <TextBlock x:Name="txtE" Grid.Row="2" Grid.Column="1" Text="[E] POC. ENERG" Foreground="Orange" Margin="5"/>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="VS" FontSize="50" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtConsola" Text="¡A LUCHAR!" Foreground="Yellow" TextAlignment="Center" FontSize="16" TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="2" Margin="10" Background="#250000FF" CornerRadius="15" BorderBrush="#880000FF" BorderThickness="2">
                <StackPanel Padding="10">
                    <TextBlock Text="JUGADOR 2 (↑←↓→ + OP)" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="txtUp" Grid.Row="0" Grid.Column="0" Text="[↑] FLOJO" Foreground="White" Margin="5"/>
                        <TextBlock x:Name="txtLeft" Grid.Row="0" Grid.Column="1" Text="[←] FUERTE" Foreground="Yellow" Margin="5"/>
                        <TextBlock x:Name="txtDown" Grid.Row="1" Grid.Column="0" Text="[↓] ESCUDO" Foreground="Cyan" Margin="5"/>
                        <TextBlock x:Name="txtRight" Grid.Row="1" Grid.Column="1" Text="[→] RELAX" Foreground="LightGreen" Margin="5"/>
                        <TextBlock x:Name="txtO" Grid.Row="2" Grid.Column="0" Text="[O] POC. VIDA" Foreground="Salmon" Margin="5"/>
                        <TextBlock x:Name="txtP" Grid.Row="2" Grid.Column="1" Text="[P] POC. ENERG" Foreground="Orange" Margin="5"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>